{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yysworld/schema/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "artifact_type",
    "snapshot_id",
    "root_id",
    "branch_id",
    "package_ref",
    "model_refs",
    "comparison_contract_version",
    "content",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "root_id": {
      "type": "string"
    },
    "branch_id": {
      "type": "string"
    },
    "package_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "package_created_at",
        "package_hash"
      ],
      "properties": {
        "package_id": {
          "type": "string"
        },
        "package_created_at": {
          "type": "string"
        },
        "package_hash": {
          "type": "string"
        }
      }
    },
    "model_refs": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://yysworld/schema/model_profile.schema.json",
        "title": "ModelProfile",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "provider",
          "model_id",
          "model_version",
          "role",
          "runtime_class",
          "parameters"
        ],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "model_version": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "generator",
              "evaluator",
              "summarizer"
            ]
          },
          "runtime_class": {
            "type": "string",
            "enum": [
              "cloud",
              "local"
            ]
          },
          "parameters": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "temperature": {
                "type": "number"
              },
              "top_p": {
                "type": "number"
              },
              "max_tokens": {
                "type": "integer"
              },
              "seed": {
                "type": [
                  "integer",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "comparison_contract_version": {
      "type": "string"
    },
    "content": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    }
  }
}
