{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yysworld/schema/world_event.schema.json",
  "title": "WorldEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "root_id",
    "story_day",
    "occurred_at",
    "event_type",
    "canonical_truth",
    "perception_prompt",
    "tags",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "event_id": {
      "type": "string"
    },
    "root_id": {
      "type": "string"
    },
    "story_day": {
      "type": "integer"
    },
    "occurred_at": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "canonical_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "entities",
        "location",
        "concrete_outcome"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "entities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "location": {
          "type": "string"
        },
        "concrete_outcome": {
          "type": "string"
        }
      }
    },
    "perception_prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noticeable_surface",
        "ambiguity_level"
      ],
      "properties": {
        "noticeable_surface": {
          "type": "string"
        },
        "ambiguity_level": {
          "type": "number"
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    }
  }
}
